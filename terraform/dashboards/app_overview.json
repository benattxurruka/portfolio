{
  "title": "Portfolio — App Overview",
  "uid": "portfolio-app-overview",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "tags": ["portfolio", "overview"],
  "panels": [
    {
      "id": 1,
      "title": "Page Views by Route",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${prometheus_ds_uid}" },
      "targets": [
        {
          "expr": "sum by (page) (increase(portfolio_page_views_total[5m]))",
          "legendFormat": "{{page}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Request Rate",
      "description": "Requests per second (proxy: session language counter fires on every server render)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${prometheus_ds_uid}" },
      "targets": [
        {
          "expr": "sum(rate(portfolio_session_language_total[1m]))",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 3,
      "title": "Log Volume by Severity",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "loki", "uid": "${loki_ds_uid}" },
      "targets": [
        {
          "expr": "sum by (severity) (count_over_time({service_name=\"portfolio\"}[1m]))",
          "legendFormat": "{{severity}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 4,
      "title": "Error & Warn Logs",
      "type": "logs",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "loki", "uid": "${loki_ds_uid}" },
      "targets": [
        {
          "expr": "{service_name=\"portfolio\", severity=~\"WARN|ERROR\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Sessions by Language",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${prometheus_ds_uid}" },
      "targets": [
        {
          "expr": "sum by (locale) (increase(portfolio_session_language_total[$__range]))",
          "legendFormat": "{{locale}}",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "pieType": "pie",
        "displayLabels": ["name", "percent"]
      }
    },
    {
      "id": 5,
      "title": "Traces",
      "type": "traces",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 16 },
      "datasource": { "type": "tempo", "uid": "${tempo_ds_uid}" },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "${tempo_ds_uid}" },
          "queryType": "traceql",
          "query": "{resource.service.name = \"portfolio\"}",
          "limit": 20,
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Page Views by Country",
      "type": "geomap",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${prometheus_ds_uid}" },
      "targets": [
        {
          "expr": "sum by (country) (increase(portfolio_page_views_total[$__range]))",
          "instant": true,
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "view": { "id": "zero", "lat": 30, "lon": 0, "zoom": 1 },
        "controls": {
          "showZoom": true,
          "mouseWheelZoom": true,
          "showAttribution": true,
          "showScale": false
        },
        "basemap": { "type": "default", "name": "Basemap" },
        "layers": [
          {
            "type": "choropleth",
            "name": "Page Views",
            "config": {
              "style": {
                "palette": "interpolateYlOrRd",
                "colorScale": "linear"
              }
            },
            "location": {
              "mode": "lookup",
              "gazetteer": "public/gazetteer/countries.json",
              "lookup": "country"
            },
            "tooltip": true
          }
        ],
        "tooltip": { "mode": "details" }
      }
    }
  ]
}
