# =============================================================================
# Cloudflare R2 — photo storage
# =============================================================================
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=portfolio-photos

# Public URL for the R2 bucket (R2 custom domain or pub-*.r2.dev URL)
# Used to build <img> src attributes — no signed URLs needed if bucket is public
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxx.r2.dev

# Only needed for next/image domain allow-list (extract hostname from R2_PUBLIC_URL)
R2_PUBLIC_HOSTNAME=pub-xxxxxxxxxxxx.r2.dev

# =============================================================================
# GitHub — repository listing
# =============================================================================
GITHUB_USERNAME=your_github_username
# Optional: raises the rate limit from 60 → 5000 requests/hour via GitHub App auth.
# Note: GITHUB_TOKEN is reserved by Vercel — use GH_TOKEN for a static PAT instead.
# Alternatively, use GitHub App auth (preferred — no expiry management):
#   GH_APP_CLIENT_ID       — client_id string from github.com/settings/apps (e.g. "Iv23li...")
#   GH_APP_INSTALLATION_ID — installation ID (github.com/settings/installations → app → ID in URL)
#   GH_APP_PRIVATE_KEY     — PEM content with literal \n for newlines
GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GH_APP_CLIENT_ID=Iv23liXXXXXXXXXX
GH_APP_INSTALLATION_ID=12345678
GH_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nMII...\n-----END RSA PRIVATE KEY-----

# =============================================================================
# Sentry — error monitoring
# =============================================================================
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@oxxxx.ingest.sentry.io/xxxx
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=portfolio
# Required to upload source maps during `next build`
SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxxxxxx

# =============================================================================
# Grafana Cloud — OTLP (traces + metrics + logs)
#
# Endpoint format: https://otlp-gateway-{zone}.grafana.net/otlp
# e.g.  https://otlp-gateway-prod-eu-west-0.grafana.net/otlp
#
# Token format: "{instanceId}:{cloudAccessPolicyToken}"  — plain text, no base64.
# The code in instrumentation.ts applies base64 encoding for the Basic Auth
# header automatically.
#
# instanceId:              numeric stack ID from grafana.com → your stack → Instance ID
# cloudAccessPolicyToken:  token from grafana.com → Security → Access Policies
#                          (policy needs metrics:write, logs:write, traces:write scopes)
# =============================================================================
GRAFANA_OTLP_ENDPOINT=https://otlp-gateway-prod-eu-west-0.grafana.net/otlp
GRAFANA_OTLP_TOKEN=123456:glc_xxxxxxxxxxxxxxxxxxxx
